generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  nome          String   @default("EDUARDO DE SOUSA SILVA")
  cadastroNum   String   @unique 
  password      String
  cargo         String   @default("CEO • DIRETOR EXECUTIVO")
  nivel         String   @default("SUPER")
  dataIngresso  DateTime @default(now())
}

model Evento {
  id           String   @id @default(cuid())
  nome         String
  data         DateTime
  cidade       String
  banner       String   
  linkIngresso String?
  apoiado      Boolean  @default(false)
  destaque     Boolean  @default(false)
  ativo        Boolean  @default(true)
}
