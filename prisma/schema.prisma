datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Evento {
  id        String   @id @default(cuid())
  nome      String
  data      DateTime
  cidade    String
  imagemUrl String
  link      String?
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}
