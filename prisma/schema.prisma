generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  nome          String   @default("Administrador")
  username      String   @unique
  password      String
  nivel         String   @default("ADMIN") // SUPER, ADMIN, EDITOR
  cadastroNum   String   @default("001")
}

model Evento {
  id           String   @id @default(cuid())
  nome         String
  data         DateTime
  cidade       String
  imagemUrl    String
  link         String?
  apoiado      Boolean  @default(false)
  ativo        Boolean  @default(true)
}
