generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  nome          String   @default("Administrador")
  cadastroNum   String   @unique // O segredo para o erro sumir está aqui
  password      String
  cargo         String   @default("Diretor")
  nivel         String   @default("SUPER")
  dataIngresso  DateTime @default(now())
}

model Evento {
  id           String   @id @default(cuid())
  nome         String
  data         DateTime
  cidade       String
  banner       String   // Certifique-se de que o campo se chama banner no actions.ts também
  linkIngresso String?
  apoiado      Boolean  @default(false)
  destaque     Boolean  @default(false)
  ativo        Boolean  @default(true)
}
